# =============================================================================
# YTRobot Configuration Example
# =============================================================================
# Copy this file to .env and fill in your API keys and preferences
# All settings can also be configured via the web UI (http://localhost:8080)

# =============================================================================
# LLM API Keys (for script generation and AI features)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIEAI_API_KEY=                    # Primary: Gemini 2.5 Flash via kie.ai — Get key at: https://kie.ai/api-key
GEMINI_API_KEY=                   # Direct Gemini API access (optional)

# =============================================================================
# Script Generation Settings
# =============================================================================
TARGET_AUDIENCE=                  # e.g., "beginner YouTubers under 1k subscribers"
SCRIPT_HUMANIZE_WITH_LLM=false    # Use LLM to rewrite script for natural speech

# =============================================================================
# TTS (Text-to-Speech) — Global Defaults
# =============================================================================
TTS_PROVIDER=speshaudio           # Options: speshaudio | elevenlabs | openai | google
TTS_SPEED=1.0                     # Speech rate: 0.5 (slow) to 2.0 (fast)
TTS_ENHANCE_WITH_LLM=false        # Add pauses/emphasis via LLM before synthesis
TTS_TRIM_SILENCE=false            # Trim leading/trailing silence
TTS_REMOVE_APOSTROPHES=true       # Strip apostrophes (prevents micro-pauses)

# --- OpenAI TTS ---
OPENAI_TTS_VOICE=onyx             # Options: alloy | ash | coral | echo | fable | nova | onyx | sage | shimmer

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- SpesAudio (Recommended for Turkish) ---
SPESHAUDIO_API_KEY=
SPESHAUDIO_VOICE_ID=
SPESHAUDIO_LANGUAGE=tr            # e.g., "tr" for Turkish, "en" for English
SPESHAUDIO_STABILITY=0.3          # 0.0 - 1.0 (higher = more stable/consistent)
SPESHAUDIO_SIMILARITY_BOOST=0.5   # 0.0 - 1.0 (higher = closer to original voice)
SPESHAUDIO_STYLE=0.75             # 0.0 - 1.0 (higher = more expressive)

# =============================================================================
# YT Video Module Overrides (optional — falls back to global if empty)
# =============================================================================
YT_TTS_PROVIDER=                  # Leave empty to inherit from TTS_PROVIDER
YT_TTS_VOICE_ID=
YT_TTS_SPEED=0                    # 0 = inherit from TTS_SPEED
YT_TTS_LANGUAGE=
YT_TTS_STABILITY=-1               # -1 = inherit from SPESHAUDIO_STABILITY
YT_TTS_SIMILARITY_BOOST=-1
YT_TTS_STYLE=-1

# YT Video Visual Overrides
YT_VISUALS_PROVIDER=              # Leave empty to inherit from VISUALS_PROVIDER
YT_REMOTION_SUBTITLE_FONT=        # Leave empty to inherit from REMOTION_SUBTITLE_FONT
YT_REMOTION_SUBTITLE_SIZE=0       # 0 = inherit from REMOTION_SUBTITLE_SIZE
YT_REMOTION_SUBTITLE_COLOR=       # Leave empty to inherit
YT_REMOTION_VIDEO_EFFECT=         # Leave empty to inherit
YT_REMOTION_SUBTITLE_ANIMATION=   # Leave empty to inherit

# =============================================================================
# Bulletin (News) Module Settings
# =============================================================================
BULLETIN_TTS_PROVIDER=            # Leave empty to inherit from TTS_PROVIDER
BULLETIN_TTS_VOICE_ID=
BULLETIN_TTS_SPEED=0
BULLETIN_TTS_LANGUAGE=
BULLETIN_TTS_STABILITY=-1
BULLETIN_TTS_SIMILARITY_BOOST=-1
BULLETIN_TTS_STYLE=-1

BULLETIN_NETWORK_NAME=YTRobot Haber
BULLETIN_STYLE=breaking           # Options: breaking | tech | corporate | sport | finance | weather | science | entertainment | dark
BULLETIN_FORMAT=16:9              # Options: 16:9 | 9:16
BULLETIN_FPS=60
BULLETIN_DEFAULT_MAX_ITEMS=3
BULLETIN_DEFAULT_LANGUAGE=        # Leave empty for per-source language
BULLETIN_CATEGORY_MAPPING=        # JSON map: category name -> style

# =============================================================================
# Product Review Module Settings
# =============================================================================
PR_TTS_PROVIDER=                  # Leave empty to inherit from TTS_PROVIDER
PR_TTS_VOICE_ID=
PR_TTS_SPEED=0
PR_TTS_LANGUAGE=
PR_TTS_STABILITY=0.3
PR_TTS_SIMILARITY=0.5
PR_TTS_STYLE=0.75

PR_AUTO_GENERATE_TTS=true         # Auto-generate TTS on render if audio missing
PR_MASTER_PROMPT=                 # Custom AI extraction instructions (shown in Product Review settings)
PR_AI_LANGUAGE=                   # Leave empty to use UI language
PR_STYLE=modern
PR_FORMAT=16:9
PR_FPS=60
PR_CHANNEL_NAME=YTRobot İnceleme
PR_CURRENCY=TL
PR_CTA_TEXT=Linke tıkla!

# =============================================================================
# Social Media Metadata Generation
# =============================================================================
SOCIAL_META_ENABLED_YT_VIDEO=false
SOCIAL_META_ENABLED_BULLETIN=false
SOCIAL_META_ENABLED_PR=false
SOCIAL_META_FIELDS=title,description,tags   # Comma-separated: title | description | tags | source | link
SOCIAL_META_MASTER_PROMPT=
SOCIAL_META_LANGUAGE=             # Leave empty to use module/global language

# =============================================================================
# Visuals — Global Settings
# =============================================================================
VISUALS_PROVIDER=pexels           # Options: pexels | pixabay | dalle | zimage
PEXELS_API_KEY=
PIXABAY_API_KEY=
ZIMAGE_ASPECT_RATIO=16:9          # Options: 1:1 | 4:3 | 3:4 | 16:9 | 9:16

# =============================================================================
# Composer & Video Effects (Remotion Preferred)
# =============================================================================
COMPOSER_PROVIDER=remotion        # Options: moviepy | remotion (remotion = higher quality)
REMOTION_CONCURRENCY=4            # 1 (low memory) to 8 (fast)
REMOTION_KEN_BURNS_ZOOM=0.08      # 0 (none) | 0.05 (subtle) | 0.08 (normal) | 0.15 (strong)
REMOTION_KEN_BURNS_DIRECTION=center  # Options: center | pan-left | pan-right | random

# Subtitle Styling
REMOTION_SUBTITLE_FONT=bebas      # Options: bebas | montserrat | oswald | roboto | inter | serif | sans
REMOTION_SUBTITLE_SIZE=68         # Font size in pixels (recommended: 60-80 for bebas)
REMOTION_SUBTITLE_COLOR=#ffffff   # Hex color code
REMOTION_SUBTITLE_BG=none         # Options: none | box | pill
REMOTION_SUBTITLE_STROKE=2        # Text stroke width in px (0 = disabled)
REMOTION_TRANSITION_DURATION=10   # Frames for fade-in (0 = disabled)
REMOTION_VIDEO_EFFECT=none        # Options: none | vignette | warm | cool | cinematic
REMOTION_KARAOKE_COLOR=#FFD700    # Highlight color for active word
REMOTION_KARAOKE_ENABLED=true     # Word-by-word highlight
REMOTION_SUBTITLE_ANIMATION=hype  # Options: hype | explosive | vibrant | minimal | none

# =============================================================================
# Subtitles
# =============================================================================
SUBTITLE_PROVIDER=pycaps          # Options: ffmpeg | pycaps (pycaps = modern animated)
PYCAPS_STYLE=hype                 # Options: hype | minimal | explosive

# =============================================================================
# Output Settings
# =============================================================================
OUTPUT_DIR=output
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30
