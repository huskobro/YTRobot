# LLM (OpenAI, used only as fallback if KIEAI_API_KEY is empty)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# kie.ai — powers Gemini 2.5 Flash for script/title/description/tags
# Get key at: https://kie.ai/api-key
KIEAI_API_KEY=

# TTS provider: "elevenlabs" | "openai" | "google" | "speshaudio"
TTS_PROVIDER=speshaudio
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
SPESHAUDIO_API_KEY=
SPESHAUDIO_VOICE_ID=

# Visuals provider: "pexels" | "pixabay" | "dalle"
VISUALS_PROVIDER=pexels
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Output
OUTPUT_DIR=output
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30
